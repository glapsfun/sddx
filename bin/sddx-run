#!/bin/sh
# sddx launcher: prefer bun, fall back to node (>=18). No other runtimes.
if [ "$#" -lt 1 ]; then
  echo "usage: sddx-run <script> [args...]" >&2
  exit 64
fi
if command -v bun >/dev/null 2>&1; then
  exec bun "$@"
fi
if command -v node >/dev/null 2>&1; then
  version=$(node --version) # vMAJOR.MINOR.PATCH — parsed in-shell, no extra process
  version=${version#v}
  major=${version%%.*}
  if [ "$major" -ge 18 ] 2>/dev/null; then
    exec node "$@"
  fi
  echo "sddx: node >= 18 required (found $(node --version))" >&2
  exit 1
fi
echo "sddx: neither bun nor node found on PATH" >&2
exit 1
